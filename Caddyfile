{
    debug
    default_sni {$DOMAIN}
}

# Zanjir - Air-gapped Caddy reverse proxy

{$DOMAIN}:{$HTTPS_PORT} {
    tls internal
    encode gzip zstd

    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server":"{$DOMAIN}:{$HTTPS_PORT}"}`
    }

    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.homeserver":{"base_url":"https://{$DOMAIN}:{$HTTPS_PORT}"}}`
    }

    handle /_matrix/* {
        reverse_proxy conduit:6167
    }

    handle /_synapse/client/* {
        reverse_proxy conduit:6167
    }

    handle_path /admin* {
        reverse_proxy admin:5000 {
            header_up X-Forwarded-Prefix /admin
        }
    }

    redir /app* /

    handle {
        reverse_proxy element-web:80
    }

    header {
        X-Frame-Options SAMEORIGIN
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }

    log {
        output stdout
        format console
    }
}

:{$HTTP_PORT} {
    redir https://{$DOMAIN}:{$HTTPS_PORT}{uri} permanent
}
